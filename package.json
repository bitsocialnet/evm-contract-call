{
  "name": "@bitsocial/evm-contract-challenge",
  "version": "0.1.0",
  "description": "Standalone EVM contract call challenge for plebbit-js",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "bitsocial",
    "plebbit",
    "pkc",
    "challenge",
    "evm",
    "viem"
  ],
  "author": "Bitsocial",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "peerDependencies": {
    "@plebbit/plebbit-js": ">=0.0.3"
  },
  "peerDependenciesMeta": {
    "@plebbit/plebbit-js": {
      "optional": true
    }
  },
  "dependencies": {
    "viem": "2.47.0"
  },
  "devDependencies": {
    "@types/node": "25.3.5",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
